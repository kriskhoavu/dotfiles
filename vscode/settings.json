{
    "vim.useSystemClipboard": true,
    "security.workspace.trust.untrustedFiles": "open",
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "workbench.layoutControl.enabled": false,
    "files.autoSave": "afterDelay",
    "editor.minimap.enabled": false,
    "window.zoomLevel": 1,
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "workbench.editorLargeFileConfirmation": 500,
    "files.maxMemoryForLargeFilesMB": 12000,
    "git.openRepositoryInParentFolders": "always",
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "editor.largeFileOptimizations": false,
    "github.copilot.nextEditSuggestions.enabled": true,
    "chat.agent.maxRequests": 150,
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.pdf": "pdf.preview"
    },
    "terminal.integrated.cursorStyle": "line",
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "explorer.confirmDelete": false,
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-dark",
    "explorer.confirmDragAndDrop": false,
    "chat.mcp.autostart": "never",
    "explorer.autoReveal": false,
    "chat.tools.terminal.autoApprove": {
        "cd": true,
        "echo": true,
        "ls": true,
        "pwd": true,
        "cat": true,
        "head": true,
        "tail": true,
        "findstr": true,
        "wc": true,
        "tr": true,
        "cut": true,
        "cmp": true,
        "which": true,
        "basename": true,
        "dirname": true,
        "realpath": true,
        "readlink": true,
        "stat": true,
        "file": true,
        "du": true,
        "df": true,
        "sleep": true,
        "grep": true,
        "git status": true,
        "git log": true,
        "git show": true,
        "git diff": true,
        "git grep": true,
        "git branch": true,
        "/^git branch\\b.*-(d|D|m|M|-delete|-force)\\b/": false,
        "Get-ChildItem": true,
        "Get-Content": true,
        "Get-Date": true,
        "Get-Random": true,
        "Get-Location": true,
        "Write-Host": true,
        "Write-Output": true,
        "Split-Path": true,
        "Join-Path": true,
        "Start-Sleep": true,
        "Where-Object": true,
        "/^Select-[a-z0-9]/i": true,
        "/^Measure-[a-z0-9]/i": true,
        "/^Compare-[a-z0-9]/i": true,
        "/^Format-[a-z0-9]/i": true,
        "/^Sort-[a-z0-9]/i": true,
        "column": true,
        "/^column\\b.*-c\\s+[0-9]{4,}/": false,
        "date": true,
        "/^date\\b.*(-s|--set)\\b/": false,
        "find": true,
        "/^find\\b.*-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
        "sort": true,
        "/^sort\\b.*-(o|S)\\b/": false,
        "tree": true,
        "/^tree\\b.*-o\\b/": false,
        "/\\(.+\\)/s": {
            "approve": false,
            "matchCommandLine": true
        },
        "/\\{.+\\}/s": {
            "approve": false,
            "matchCommandLine": true
        },
        "/`.+`/s": {
            "approve": false,
            "matchCommandLine": true
        },
        "rm": true,
        "rmdir": true,
        "del": true,
        "Remove-Item": false,
        "ri": false,
        "rd": false,
        "erase": false,
        "dd": false,
        "kill": false,
        "ps": false,
        "top": false,
        "Stop-Process": false,
        "spps": false,
        "taskkill": false,
        "taskkill.exe": false,
        "curl": true,
        "wget": true,
        "Invoke-RestMethod": false,
        "Invoke-WebRequest": false,
        "irm": false,
        "iwr": false,
        "chmod": true,
        "chown": true,
        "Set-ItemProperty": false,
        "sp": false,
        "Set-Acl": false,
        "jq": false,
        "xargs": true,
        "eval": true,
        "Invoke-Expression": false,
        "iex": false,
        "./gradlew": true,
        "gradle": true,
        "docker": true
    },
    "chat.tools.global.autoApprove": true,
    "git.autofetch": true,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "atlascode.jira.enabled": false,
    "atlascode.bitbucket.explorer.enabled": true,
    "files.exclude": {
        "**/var/folders/": true,
        "**/.DS_Store": true,
    },
    "search.exclude": {
        "**/dist/": true,
        "**/build/": true,
        "**/node_modules/": true,
        "**/var/folders/": true,
        "**/.DS_Store": true,
    },
    "diffEditor.renderSideBySide": true,
    "gitlens.graph.scrollMarkers.additionalTypes": [
        "stashes",
        "tags"
    ],
    "gitlens.graph.minimap.enabled": false,
    "redhat.telemetry.enabled": true,
    "vs-kubernetes": {
        "vscode-kubernetes.minikube-path-mac": "/Users/kdvu/.vs-kubernetes/tools/minikube/darwin-arm64/minikube",
        "vs-kubernetes.minikube-show-information-expiration": "2026-07-30T16:51:17.819Z"
    },
    "chat.mcp.gallery.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "chat.useAgentSkills": true,
    "chat.useNestedAgentsMdFiles": true,
    "chat.viewWelcome.enabled": false,
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "chat.viewSessions.orientation": "stacked",
    "workbench.colorTheme": "One Dark Pro Darker",
    "chat.editing.autoAcceptDelay": 100,

}