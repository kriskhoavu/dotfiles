root = true

[*.{java,gradle}]
indent_style = space
indent_size = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 300
charset = utf-8

[*.{yaml,yml}]
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 300
charset = utf-8

[*.{js,jsx,ts,tsx}]
indent_style = tab
indent_size = 1
tab_width = 3
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 300
charset = utf-8

# Windows files
[*.bat]
end_of_line = crlf
